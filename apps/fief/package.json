{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "saleor-app-fief",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check-types": "tsc",
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "generate": "pnpm run /^generate:.*/",
    "generate:app": "graphql-codegen",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "start": "next start",
    "test": "pnpm run test:unit",
    "test:ci": "pnpm run test:unit --coverage",
    "test:integration": "vitest --project=integration run",
    "test:unit": "vitest --project=unit"
  },
  "config": {
    "saleor": {
      "schemaVersion": "3.22"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@saleor/app-sdk": "link:../../node_modules/@saleor/app-sdk",
    "@saleor/apps-shared": "workspace:*",
    "@saleor/apps-trpc": "workspace:*",
    "@saleor/apps-ui": "workspace:*",
    "@saleor/macaw-ui": "catalog:",
    "@saleor/react-hook-form-macaw": "workspace:*",
    "@saleor/webhook-utils": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/next": "catalog:",
    "@trpc/react-query": "catalog:",
    "@trpc/server": "catalog:",
    "graphql": "catalog:",
    "graphql-tag": "catalog:",
    "modern-errors": "catalog:",
    "modern-errors-serialize": "catalog:",
    "mongodb": "^6.3.0",
    "neverthrow": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "tslog": "4.9.2",
    "urql": "catalog:",
    "usehooks-ts": "catalog:",
    "zod": "catalog:",
    "zod-validation-error": "catalog:"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typed-document-node": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@graphql-codegen/typescript-urql": "catalog:",
    "@graphql-typed-document-node/core": "catalog:",
    "@saleor/eslint-config-apps": "workspace:*",
    "@saleor/typescript-config-apps": "workspace:*",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.2.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "catalog:",
    "@types/react": "18.2.5",
    "@types/react-dom": "18.2.5",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-n": "catalog:",
    "graphql-codegen-typescript-operation-types": "catalog:",
    "graphql-config": "5.0.3",
    "jose": "5.10.0",
    "mongodb-memory-server": "10.4.3",
    "msw": "2.10.2",
    "next-test-api-route-handler": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
