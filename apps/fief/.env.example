# See src/lib/env.ts for the exhaustive list of supported and required env variables.

# ---- Crypto / secrets ----

# AES-256-CBC key, hex-encoded (16 or 32 bytes). Generate with `openssl rand -hex 32`.
SECRET_KEY=

# Rotation target. When set, new writes use NEW_SECRET_KEY and SECRET_KEY becomes
# decrypt-only. After rotation completes, swap SECRET_KEY = old NEW_SECRET_KEY and
# unset NEW_SECRET_KEY. See @saleor/apps-shared/secret-key-resolution.
# NEW_SECRET_KEY=

# ---- Saleor app metadata ----

# Regex pattern controlling which Saleor domains can install this app.
ALLOWED_DOMAIN_PATTERN=/*/

# APL backend. Use `mongodb` for production; `file` for local dev.
# APL=file

# Log level. One of: fatal | error | warn | info | debug | trace
# APP_LOG_LEVEL=info

# When developed locally with Saleor inside docker:
#   APP_IFRAME_BASE_URL=http://localhost:3000   (Dashboard on host reaches iframe)
#   APP_API_BASE_URL=http://host.docker.internal:3000   (Saleor in container reaches App on host)
# Leave both empty when using tunnels — Next falls back to localhost:3000.
# APP_IFRAME_BASE_URL=
# APP_API_BASE_URL=

# Identifier emitted in the manifest. Must be unique per app deployment.
# MANIFEST_APP_ID=saleor.app.fief

# Display name in the Saleor dashboard.
# APP_NAME=Fief

# ---- MongoDB (config + identity-map storage) ----

# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DATABASE=saleor_fief

# ---- Fief integration ----

# Base URL of the Fief admin/OIDC tenant the app talks to (e.g. https://auth.opensensor.io).
# FIEF_BASE_URL=

# ---- Kill switches (incident response) ----

# Set to "true" to short-circuit the inbound Fief webhook receiver.
# FIEF_SYNC_DISABLED=false

# Set to "true" to suppress all Saleor -> Fief outbound sync (CUSTOMER_* webhooks + reconciliation push).
# FIEF_SALEOR_TO_FIEF_DISABLED=false

# ---- Cron / reconciliation ----

# Bearer token required on the reconciliation cron endpoint.
# CRON_SECRET=

# ---- Plugin auth (T58 / T18-T21) ----

# Shared HMAC secret used by the Saleor BasePlugin (T56/T57) when calling the
# auth-plane endpoints (T18-T21). Must match the secret configured on the
# Saleor side. Generate with `openssl rand -hex 32`. Required at runtime.
FIEF_PLUGIN_HMAC_SECRET=
