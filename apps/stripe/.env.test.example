SECRET_KEY="C2BBB6A1306F2103D1222BE09DC4364DEFDDCAC783CDE3CDE9F8A88D3D8B0442"
APP_LOG_LEVEL=info
AWS_REGION=localhost
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_MAIN_TABLE_NAME=stripe-main-table-integration
APL=dynamodb
APP_NAME="Stripe TEST"


INTEGRATION_STRIPE_PK= # Stripe public key - generated in Stripe dashboard
INTEGRATION_STRIPE_RK= # Stripe restricted key - generated in Stripe dashboard
INTEGRATION_SALEOR_API_URL= # Currently can be non existing URL, but must be setup APL before running tests

E2E_BASE_URL= # Test client url that will be used by e2e to pay with Stripe
E2E_SALEOR_API_URL= # Saleor API url that tests will run against
E2E_CHARGE_CHANNEL_SLUG= # Slug of channel that has transactionFlow: CHARGE set
E2E_AUTHORIZATION_CHANNEL_SLUG= # Slug of channel that has transactionFlow: AUTHORIZATION set

# ──────────────────────────────────────────────────────────────────────────────
# T33: Subscription E2E (Stripe test clock + Saleor owlbooks channel)
#
# All variables below are OPTIONAL. When unset, the subscription scenarios
# under e2e/subscriptions/ skip with a clear message instead of failing.
# Required to actually exercise the flows. See e2e/subscriptions/README.md.
# ──────────────────────────────────────────────────────────────────────────────

# Stripe test-mode credentials (sk_test_..., pk_test_...). Use a sandbox account
# dedicated to E2E so test clocks and customers can be wiped freely.
E2E_STRIPE_TEST_SECRET_KEY=        # sk_test_...
E2E_STRIPE_PUBLISHABLE_KEY=        # pk_test_...
E2E_STRIPE_WEBHOOK_SECRET=         # whsec_... — for the test-mode webhook endpoint receiving events
E2E_STRIPE_PRICE_BASIC_MONTHLY=    # price_test_... created in Stripe test mode
E2E_STRIPE_PRICE_PRO_MONTHLY=      # price_test_... created in Stripe test mode

# Saleor instance with the `owlbooks` channel + digital subscription products seeded.
# Reuses E2E_SALEOR_API_URL above.
E2E_SALEOR_OWLBOOKS_CHANNEL_SLUG=owlbooks
E2E_SALEOR_VARIANT_BASIC=          # UHJvZHVjdFZhcmlhbnQ6... base64 ProductVariant ID
E2E_SALEOR_VARIANT_PRO=            # UHJvZHVjdFZhcmlhbnQ6... base64 ProductVariant ID

# A Fief test user (must exist in the Fief instance the stripe-app talks to).
# The HMAC + Fief JWT auth on /api/public/subscriptions/* requires both to match.
E2E_FIEF_TEST_USER_ID=             # uuid
E2E_FIEF_TEST_USER_EMAIL=          # e2e+subs@example.test
